# EditorConfig helps maintain consistent coding styles for multiple developers
# working on the same project across various editors and IDEs.
# https://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
max_line_length = 120
trim_trailing_whitespace = true

# Tab indentation (no size specified)
[Makefile]
indent_style = tab

## Markdown
[*.md]
indent_size = false  # May vary
trim_trailing_whitespace = true

# Plain text — indent style varies by file origin (e.g. generated SVN READMEs)
[*.txt]
indent_size = unset

# Python
# [*.py]

# Ruby
[{*.rb,*.gemspec,Gemfile{,.lock},Rakefile,Vagrantfile}]
indent_size = 2

# Front End Languages (HTML,JS,CSS etc)
[*.{css,js,html}]
indent_size = 2

[*.json]
indent_size = 2
max_line_length = off

# YAML Based files
[*.{yml,yaml,sls}]
indent_size = 2
